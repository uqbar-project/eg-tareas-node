{
  "name": "eg-tareas-node",
  "version": "1.0.0",
  "type": "module",
  "description": "Backend con paginación para el ejemplo de tareas",
  "main": "index.js",
  "scripts": {
    "start:dev": "tsx watch src/index.ts",
    "lint": "biome check src",
    "lint:fix": "biome check src --write",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "clean": "rm -rf dist node_modules coverage",
    "prepare": "husky install"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@faker-js/faker": "10.5.0",
    "cors": "2.8.6",
    "date-fns": "4.4.0",
    "express": "5.2.1",
    "express-async-handler": "1.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "25.9.3",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-v8": "4.1.9",
    "@vitest/ui": "4.1.9",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "supertest": "7.2.2",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc}": [
      "biome check --write"
    ]
  }
}
