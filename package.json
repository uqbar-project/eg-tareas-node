{
  "name": "eg-tareas-node",
  "version": "1.0.0",
  "type": "module",
  "description": "Backend con paginación para el ejemplo de tareas (NestJS)",
  "main": "dist/main.js",
  "scripts": {
    "start:dev": "nest start --watch",
    "start": "node dist/main.js",
    "build": "nest build",
    "lint": "biome check src",
    "lint:fix": "biome check src --write",
    "test": "vitest",
    "coverage": "vitest run --coverage",
    "clean": "rm -rf dist node_modules coverage",
    "prepare": "husky install"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@faker-js/faker": "10.5.0",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "date-fns": "4.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@types/node": "25.9.3",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-v8": "4.1.9",
    "@vitest/ui": "4.1.9",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "supertest": "7.2.2",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "pnpm": {
    "overrides": {
      "multer": "2.2.0"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc}": [
      "biome check --write"
    ]
  }
}
